<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app sends Apple Events (NSAppleScript) to browsers to read open tab
         URLs. Under the hardened runtime (required for notarization) an app may
         not send Apple Events without this entitlement. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
